# Strava credentials, base64-encoded (light obfuscation, NOT real encryption).
# Encode each value with: printf '%s' 'your-value' | base64
STRAVA_EMAIL=base64-encoded-strava-email
STRAVA_PASSWORD=base64-encoded-strava-password

# Optional: Gmail App Password for the STRAVA_EMAIL inbox, base64-encoded.
# Only needed if Strava challenges the login with a one-time code emailed to
# that address - the app reads it automatically over IMAP when this is set.
# Requires 2-Step Verification on the Google account; generate one at
# https://myaccount.google.com/apppasswords
# GMAIL_APP_PASSWORD=base64-encoded-gmail-app-password
